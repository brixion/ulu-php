{
    "name": "brixion/ulu-php",
    "description": "Typed PHP SDK for the ULU (CarTracker) REST API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Brixion\\Ulu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brixion\\Ulu\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "php -d memory_limit=512M vendor/bin/phpstan analyse --configuration=phpstan.neon"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
